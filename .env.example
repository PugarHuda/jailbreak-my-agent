# CROO CAP SDK credentials — get these from the Agent Store after registering.
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# The service id you registered for the `redteam_scan` service.
CROO_SERVICE_ID=svc_xxxxxxxx

# For the buyer simulator (examples/requester.ts): the service id to hire.
CROO_TARGET_SERVICE_ID=svc_xxxxxxxx

# Optional. Base RPC for on-chain reads. Defaults handled by SDK.
BASE_RPC_URL=

# Optional but IMPORTANT for a real CAP demo: the buyer must be a DIFFERENT agent
# than this scanner. Set to a second agent's SDK key so the order is a genuine
# cross-wallet counterparty (not a self-order). Unset = uses CROO_SDK_KEY (self-order).
BUYER_SDK_KEY=
