# CROO CAP SDK credentials — get these from the Agent Store after registering.
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# The service id you registered for the `redteam_scan` service.
CROO_SERVICE_ID=svc_xxxxxxxx

# Optional. Base RPC for on-chain reads. Defaults handled by SDK.
BASE_RPC_URL=
